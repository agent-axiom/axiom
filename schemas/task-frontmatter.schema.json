{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AXIOM Task Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "kind",
    "status",
    "created_at",
    "updated_at",
    "repo_root",
    "base_branch",
    "base_commit",
    "branch",
    "worktree",
    "isolation_mode",
    "risk",
    "review_required",
    "verification_required",
    "manual_smoke_required",
    "docs_status"
  ],
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "kind": {"type": "string"},
    "status": {"type": "string"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "repo_root": {"type": "string"},
    "base_branch": {"type": "string"},
    "base_commit": {"type": "string"},
    "branch": {"type": "string"},
    "worktree": {"type": "string"},
    "isolation_mode": {"enum": ["worktree", "degraded"]},
    "risk": {"type": "string"},
    "review_required": {"type": "boolean"},
    "verification_required": {"type": "boolean"},
    "manual_smoke_required": {"type": "boolean"},
    "docs_status": {"type": "string"},
    "blocked_reason": {"type": "string"}
  }
}
