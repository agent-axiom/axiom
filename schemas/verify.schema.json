{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AXIOM Verify Result",
  "type": "object",
  "required": ["outcome", "summary", "automated_checks", "negative_checks", "manual_smoke", "failures"],
  "properties": {
    "outcome": {
      "enum": ["passed", "failed", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "automated_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commandReceipt"
      }
    },
    "negative_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commandReceipt"
      }
    },
    "manual_smoke": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "notes"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["passed", "failed", "waived"]},
          "notes": {"type": "string"}
        }
      }
    },
    "failures": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "commandReceipt": {
      "type": "object",
      "required": ["name", "command", "status", "exit_code", "stdout", "stderr", "policy"],
      "properties": {
        "name": {"type": "string"},
        "command": {"type": "string"},
        "status": {"enum": ["passed", "failed", "blocked"]},
        "exit_code": {"type": "integer"},
        "stdout": {"type": "string"},
        "stderr": {"type": "string"},
        "policy": {"enum": ["allow", "deny", "escalate"]},
        "policy_reason": {"type": "string"}
      }
    }
  }
}
